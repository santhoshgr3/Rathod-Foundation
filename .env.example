# Supabase — copy this file to ".env" and fill in your project values.
# Find them in: Supabase Dashboard → Project Settings → API
# The anon key is safe in the browser (protected by row-level security).
# NEVER put the service_role key here or anywhere in the frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
